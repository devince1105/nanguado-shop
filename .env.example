# ============================================================
# 南瓜多商鋪 環境變數範本
# 使用方式：cp .env.example .env，再依需求填入實際數值
# 此檔案會被 apps/web、apps/api、packages/db 共用（apps/web/.env 是指向本檔的 symlink）
# ============================================================

# ---------- 資料庫 (Neon PostgreSQL) ----------
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# ---------- JWT（會員登入 Token 簽章密鑰） ----------
# 正式環境務必改成高強度亂數字串，勿沿用範例值。缺少此值 API 會直接啟動失敗。
JWT_SECRET=please-change-this-to-a-long-random-secret

# ---------- 服務網址（Webhook 回調 / CORS 白名單用） ----------
# 後端 API 對外可存取的網址；本地測試綠界 Webhook 需搭配 ngrok / localtunnel 取得公網網址
API_BASE_URL=http://localhost:4000
# 前端網址；CORS 白名單，多個網域以逗號分隔
WEB_BASE_URL=http://localhost:3000
# 後端監聽 Port
PORT=4000

# ---------- 綠界金流 ECPay（信用卡付款） ----------
# 以下為綠界官方公開的測試商店金鑰（MerchantID 2000132），可直接用於本地開發測試
# 正式上線前務必換成綠界後台申請到的正式商店金鑰，否則無法收到真實款項
ECPAY_MERCHANT_ID=2000132
ECPAY_HASH_KEY=5294y06JbISpM5x9
ECPAY_HASH_IV=v77hoKGq4kWxNNIS
# 測試環境收銀台網址；正式環境請改為 https://payment.ecpay.com.tw/Cashier/AioCheckOut/V5
ECPAY_ACTION_URL=https://payment-stage.ecpay.com.tw/Cashier/AioCheckOut/V5

# ---------- 綠界電子發票（可與付款金鑰不同商店） ----------
ECPAY_INVOICE_MERCHANT_ID=2000132
ECPAY_INVOICE_HASH_KEY=ejCk326UnaZWKisg
ECPAY_INVOICE_HASH_IV=q9jcZX8Ib9LM8wYk

# ---------- 綠界物流（超商取貨 / 貨到付款） ----------
ECPAY_LOGISTICS_MERCHANT_ID=2000933
ECPAY_LOGISTICS_HASH_KEY=XBERn1YOvpM9nfZc
ECPAY_LOGISTICS_HASH_IV=h1ONHk4P4yqbl5LK
# 留白則預設打測試環境物流 API；正式環境請改為 https://logistics.ecpay.com.tw/Express/Create
ECPAY_LOGISTICS_ACTION_URL=

# ---------- Google 登入 ----------
# 前後端須填「同一組」Google OAuth Client ID（此 ID 本身非密鑰，可公開於前端）
# 未設定時登入頁不會顯示 Google 登入按鈕
GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ---------- 前端呼叫後端 API 的網址（瀏覽器端使用） ----------
NEXT_PUBLIC_API_URL=http://localhost:4000

# ---------- 寄信設定（擇一：Resend HTTP API 或 SMTP；都未設定則僅印 log，不真的寄信） ----------
# 方式一：Resend（推薦，走 443 port，避免主機商封鎖 SMTP）
RESEND_API_KEY=
# 方式二：一般 SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=南瓜多 本舖 <no-reply@nanguado.shop>

# ---------- Cloudflare R2（媒體庫圖片儲存） ----------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=
